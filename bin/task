#!/bin/sh
# Task CLI - Global entry point for task-decomposer skill
# This script should be installed to a directory in PATH (e.g., ~/.local/bin)
# Supports: macOS, Linux, Windows (Git Bash/WSL)
#
# Installation:
#   ./scripts/install.sh install
#   # or manually:
#   cp bin/task ~/.local/bin/task && chmod +x ~/.local/bin/task
#
# Usage:
#   task <command> [args]

set -e

SKILL_NAME="task-decomposer"

if [ -z "${HOME:-}" ]; then
    HOME="${USERPROFILE:-$(cd ~ && pwd)}"
fi

resolve_script_path() {
    target="$1"

    while [ -L "$target" ]; do
        target_dir="$(cd "$(dirname "$target")" && pwd)"
        link_target="$(readlink "$target")"
        case "$link_target" in
            /*) target="$link_target" ;;
            *) target="${target_dir}/${link_target}" ;;
        esac
    done

    target_dir="$(cd "$(dirname "$target")" && pwd)"
    echo "${target_dir}/$(basename "$target")"
}

find_bundled_skill_dir() {
    script_path="$(resolve_script_path "$0")"
    script_dir="$(dirname "$script_path")"
    skill_dir="$(dirname "$script_dir")"

    if [ -f "${skill_dir}/bin/harness.sh" ] && [ -f "${skill_dir}/lib/common.sh" ]; then
        echo "$skill_dir"
        return 0
    fi

    return 1
}

find_skill_dir() {
    for dir in \
        "${SKILL_DIR:-}" \
        "${HOME}/.qoder/skills/${SKILL_NAME}" \
        "${HOME}/.trae-cn/skills/${SKILL_NAME}" \
        "${HOME}/.trae/skills/${SKILL_NAME}" \
        "${HOME}/.claude/skills/${SKILL_NAME}" \
        "${HOME}/.cursor/skills/${SKILL_NAME}" \
        "${HOME}/.skills/${SKILL_NAME}"
    do
        if [ -n "$dir" ] && [ -d "$dir" ]; then
            echo "$dir"
            return 0
        fi
    done
    return 1
}

main() {
    SKILL_DIR="$(find_bundled_skill_dir || true)"
    if [ -z "$SKILL_DIR" ]; then
        SKILL_DIR=$(find_skill_dir)
    fi
    if [ -z "$SKILL_DIR" ]; then
        echo "Error: task-decomposer skill not found"
        echo ""
        echo "Searched locations:"
        echo "  - \$SKILL_DIR (if set)"
        echo "  - ~/.qoder/skills/task-decomposer"
        echo "  - ~/.trae-cn/skills/task-decomposer"
        echo "  - ~/.trae/skills/task-decomposer"
        echo "  - ~/.claude/skills/task-decomposer"
        echo "  - ~/.cursor/skills/task-decomposer"
        echo "  - ~/.skills/task-decomposer"
        echo ""
        echo "To install, run: ./scripts/install.sh install"
        exit 1
    fi

    HARNESS="${SKILL_DIR}/bin/harness.sh"
    if [ ! -f "$HARNESS" ]; then
        echo "Error: harness.sh not found at $HARNESS"
        exit 1
    fi

    COMMON_SH="${SKILL_DIR}/lib/common.sh"
    if [ ! -f "$COMMON_SH" ]; then
        echo "Error: common.sh not found at $COMMON_SH"
        exit 1
    fi

    export SKILL_DIR
    . "$COMMON_SH"

    PROJECT_ROOT=$(get_project_root)
    export PROJECT_ROOT

    exec "$HARNESS" "$@"
}

main "$@"
